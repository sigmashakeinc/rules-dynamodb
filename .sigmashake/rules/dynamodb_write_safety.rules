# dynamodb_write_safety.rules
# Technology: dynamodb | Capability: write

rule dynamodb-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "Scan"
  MESSAGE "Blocked an unsafe pattern in dynamodb. Use the recommended best practices for 2025/2026."
}

rule dynamodb-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Expected"
  MESSAGE "You are using an outdated API for dynamodb. Please upgrade to the newer API."
}
